# Copy to .env (which is gitignored) and fill in real values locally.
# In Azure, set these as Application Settings or, better, Key Vault references.
# This file lists the variable NAMES only — never put real keys here.

# Anthropic API key. Server-side only. Never shipped to the browser.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Which versioned prompt the proxy loads from /prompts (e.g. v1, v2).
PROMPT_VERSION=v1

# Set to 1 to run evals against the LIVE model instead of fixtures.
# Requires ANTHROPIC_API_KEY. Leave unset for deterministic CI runs.
# EVAL_LIVE=1
